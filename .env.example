# ─────────────────────────────────────────────────────────────────────────────
# Shalina Healthcare — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it contains secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure AD / Service Principal ─────────────────────────────────────────────
# Found in: Azure Portal → Azure Active Directory → App Registrations
FABRIC_TENANT_ID=your-tenant-id-here
FABRIC_CLIENT_ID=your-client-id-here
FABRIC_CLIENT_SECRET=your-client-secret-here

# ── Fabric SQL Analytics Endpoint (PRIMARY — fastest connection) ──────────────
# How to find:
#   1. Go to app.fabric.microsoft.com
#   2. Open your Warehouse or Lakehouse
#   3. Click ⚙ Settings → copy the "SQL connection string"
#      It looks like: abc123.datawarehouse.fabric.microsoft.com
FABRIC_SQL_ENDPOINT=your-warehouse.datawarehouse.fabric.microsoft.com
FABRIC_SQL_DATABASE=Shalina_Warehouse

# ── Power BI REST API / DAX (FALLBACK) ───────────────────────────────────────
# Found in: Power BI Service → Workspace Settings / Dataset Settings
FABRIC_WORKSPACE_ID=your-workspace-id-here
FABRIC_DATASET_ID=your-dataset-id-here

# ── SFA Reports (for real RFM data — requires IT to grant access) ─────────────
FABRIC_SFA_DATASET_ID=your-sfa-dataset-id-here
FABRIC_USERNAME=your-email@shalina.com
FABRIC_PASSWORD=your-password-here
